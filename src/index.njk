<!-- Final CTA -->
<section id="contact" class="px-6 py-20">
    <div class="max-w-4xl mx-auto glass p-8 sm:p-12 md:p-20 rounded-[2rem] sm:rounded-[3rem] text-center space-y-8 relative overflow-hidden shadow-2xl border-white/5">
        <div class="absolute inset-0 bg-gradient-to-br from-primary-500/10 to-purple-500/10 -z-10 animate-pulse transition-duration-5000"></div>
        <h2 class="text-3xl sm:text-5xl font-black font-display tracking-tight">Ready to elevate and unleash your data?</h2>
                <p class="text-lg sm:text-xl text-slate-300 max-w-xl mx-auto leading-relaxed">
                    Whether you need strategic coaching or hands-on implementation of machine-actionable metadata, I'm looking forwards to collaborating with you.
                </p>
                <div class="text-sm text-slate-400 mt-2">Based in Canada 🇨🇦 • Operating Globally 🌎</div>
        <div class="flex flex-col sm:flex-row justify-center items-center gap-6 pt-6" x-data="{ copied: false, email: 'pascal@highvaluedata.net' }">
             <!-- Email Click-to-Copy -->
             <button 
                @click="navigator.clipboard.writeText(email); copied = true; setTimeout(() => copied = false, 2000)"
                class="group relative flex items-center space-x-3 px-8 py-4 rounded-full transition-all duration-300 w-full sm:w-auto overflow-hidden"
                :class="copied ? 'bg-green-600 shadow-xl shadow-green-500/20' : 'bg-primary-600 hover:bg-primary-500 shadow-xl shadow-primary-500/20'"
             >
                <div class="flex items-center space-x-3 z-10">
                    <svg x-show="!copied" class="w-5 h-5 text-white/70" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                    <svg x-show="copied" x-cloak class="w-5 h-5 text-white animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                    <span class="font-bold tracking-tight text-white" x-text="copied ? 'Email Copied!' : email"></span>
                </div>
                
                <span class="absolute inset-0 bg-white/10 opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none"></span>
                
                <span class="absolute -top-10 left-1/2 -translate-x-1/2 px-3 py-1 bg-slate-800 text-[10px] text-white rounded opacity-0 group-hover:opacity-100 transition-all pointer-events-none uppercase tracking-widest font-black whitespace-nowrap z-30">
                    Click to Copy
                </span>
             </button>

             <!-- LinkedIn Button -->
             <a href="https://linkedin.com/in/pascal" target="_blank" class="glass px-10 py-4 rounded-full font-bold hover:bg-white/10 transition-all border-white/10 flex items-center space-x-2 w-full sm:w-auto justify-center">
                <svg class="w-5 h-5 text-[#0A66C2]" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
                <span>Connect on LinkedIn</span>
             </a>
        </div>
    </div>
</section>
