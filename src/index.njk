---
layout: layouts/base.njk
title: Pascal Heus | Data, Metadata & AI Strategist
---

<!-- Hero Section (0-3 seconds) -->
<section class="relative min-h-screen flex items-center px-6 overflow-hidden pt-20">
    <div class="max-w-7xl mx-auto relative z-10 text-center lg:text-left">
        <div class="max-w-4xl mx-auto lg:mx-0 space-y-8"
             x-data="{ show: false }" x-init="setTimeout(() => show = true, 100)"
             x-show="show" x-transition:enter="transition ease-out duration-1000" x-transition:enter-start="opacity-0 translate-y-10" x-transition:enter-end="opacity-100 translate-y-0">
            
            <h1 class="text-3xl sm:text-5xl md:text-7xl font-black font-display leading-[1.1] md:leading-[0.95] tracking-tighter">
                Elevating <span class="text-gradient">Data</span> into Actionable <span class="text-gradient">Knowledge.</span>
            </h1>
            
            <p class="text-lg sm:text-xl text-slate-300 max-w-2xl leading-relaxed mx-auto lg:mx-0">
                I transform fragmented, undocumented datasets into high-value digital commodities. 
                By leveraging <strong>FAIR principles</strong>, <strong>metadata driven automated pipelines</strong>, 
                and <strong>machine intelligence</strong>, I help organizations bridge the gap between dark data 
                and user-friendly AI-ready digital data products.
            </p>

            <div class="flex flex-col sm:flex-row gap-4 pt-4 justify-center lg:justify-start">
                <a href="/#contact" class="btn-primary flex justify-center items-center">
                    Book a Data Strategy Consultation
                </a>
                <a href="https://linkedin.com/in/pascal" target="_blank" class="glass px-6 py-3 rounded-full font-semibold flex justify-center items-center hover:bg-white/10 transition-all">
                    View LinkedIn
                </a>
            </div>
        </div>
    </div>
    
    <div class="absolute bottom-10 left-1/2 -translate-x-1/2 animate-bounce opacity-50">
        <svg class="w-6 h-6 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7-7-7m14-8l-7 7-7-7"></path></svg>
    </div>
</section>

<!-- Trust Ribbon — Animated Ticker -->
<section id="trust" class="py-16 bg-slate-900/40 px-6 border-y border-white/5 overflow-hidden">
    <div class="max-w-7xl mx-auto">
        <div class="mb-10 text-center">
            <p class="text-xs font-black uppercase tracking-[0.2em] text-slate-500 mb-2">Strategic Expertise for Global Data Governance</p>
            <div class="h-1 w-16 bg-primary-500/30 rounded-full mx-auto"></div>
        </div>
    </div>

    <!-- Ticker wrapper with fade edges -->
    <div class="relative" style="-webkit-mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent); mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);">
        <div class="flex animate-ticker" style="width: max-content;">
            <!-- First copy -->
            {% for org in trust %}
            <a href="{{ org.url }}" target="_blank" title="{{ org.name }}" class="flex flex-col items-center group transition-all duration-300 hover:scale-105 opacity-80 hover:opacity-100 mx-12 md:mx-16 shrink-0">
                <img src="{{ org.logo }}" alt="{{ org.name }}" class="h-12 md:h-16 max-w-[160px] w-auto object-contain brightness-125 grayscale-[50%] group-hover:grayscale-0 group-hover:brightness-100 transition-all duration-300 {{ 'invert' if org.invert }}">
            </a>
            {% endfor %}
            <!-- Duplicate for seamless loop -->
            {% for org in trust %}
            <a href="{{ org.url }}" target="_blank" title="{{ org.name }}" class="flex flex-col items-center group transition-all duration-300 hover:scale-105 opacity-80 hover:opacity-100 mx-12 md:mx-16 shrink-0">
                <img src="{{ org.logo }}" alt="{{ org.name }}" class="h-12 md:h-16 max-w-[160px] w-auto object-contain brightness-125 grayscale-[50%] group-hover:grayscale-0 group-hover:brightness-100 transition-all duration-300 {{ 'invert' if org.invert }}">
            </a>
            {% endfor %}
        </div>
    </div>

    <style>
        @keyframes ticker {
            0% { transform: translateX(0); }
            100% { transform: translateX(-50%); }
        }
        .animate-ticker {
            animation: ticker 20s linear infinite;
        }
        .animate-ticker:hover {
            animation-play-state: paused;
        }
    </style>
</section>

<!-- Three Pillars Grid -->
<section id="expertise" class="py-20 px-6">
    <div class="max-w-7xl mx-auto">
        <div class="mb-12 space-y-4 text-center">
            <h2 class="text-4xl md:text-5xl font-bold font-display tracking-tight">Core <span class="text-gradient">Pillars</span></h2>
            <div class="h-1.5 w-24 bg-primary-500 rounded-full mx-auto"></div>
            <p class="text-slate-400 max-w-2xl mx-auto">Solving the most critical challenges in modern data governance.</p>
        </div>

        <div class="grid md:grid-cols-3 gap-8">
            <!-- Automation & AI Readiness -->
            <div class="glass p-8 rounded-2xl hover:border-primary-500/50 transition-all duration-300 group flex flex-col hover:shadow-2xl hover:shadow-primary-500/10">
                <div class="h-12 w-12 bg-primary-500/10 rounded-xl flex items-center justify-center mb-6 group-hover:scale-110 group-hover:bg-primary-500/20 transition-all">
                    <svg aria-hidden="true" class="w-6 h-6 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                </div>
                <h3 class="text-xl font-bold mb-3">Automation & AI Readiness</h3>
                <div class="space-y-4 flex-grow">
                    <div>
                        <span class="text-[10px] font-black uppercase tracking-[0.2em] text-red-400">Problem</span>
                        <p class="text-sm text-slate-400 leading-relaxed mt-1">Your data and documentation may be "human-readable", but is likely invisible to machines.</p>
                    </div>
                    <div>
                        <span class="text-[10px] font-black uppercase tracking-[0.2em] text-green-400">Solution</span>
                        <p class="text-sm text-slate-300 leading-relaxed mt-1">
                        I build high-performance <strong>APIs</strong> and <strong>metadata driven frameworks</strong> 
                        that power process automation and transform stagnant data silos into structured,
                        machine-ready assets.</p>
                    </div>
                </div>
            </div>

            <!-- Data Trust & Compliance -->
            <div class="glass p-8 rounded-2xl hover:border-purple-500/50 transition-all duration-300 group flex flex-col hover:shadow-2xl hover:shadow-purple-500/10">
                <div class="h-12 w-12 bg-purple-500/10 rounded-xl flex items-center justify-center mb-6 group-hover:scale-110 group-hover:bg-purple-500/20 transition-all">
                    <svg aria-hidden="true" class="w-6 h-6 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
                </div>
                <h3 class="text-xl font-bold mb-3">Data Quality & Trust</h3>
                <div class="space-y-4 flex-grow">
                    <div>
                        <span class="text-[10px] font-black uppercase tracking-[0.2em] text-red-400">Problem</span>
                        <p class="text-sm text-slate-400 leading-relaxed mt-1">Lack of machine-actionable documentation, proper packaging, or privacy issues affect data sharing.</p>
                    </div>
                    <div>
                        <span class="text-[10px] font-black uppercase tracking-[0.2em] text-green-400">Solution</span>
                        <p class="text-sm text-slate-300 leading-relaxed mt-1">
                        I combine specialized tools, creative programming, and AI with my data science and engineering expertise to 
                        transform your data into high-quality products, that meet the needs of data users, developers, and AI agents.
                        </p>
                    </div>
                </div>
            </div>

            <!-- Global Interoperability -->
            <div class="glass p-8 rounded-2xl hover:border-green-500/50 transition-all duration-300 group flex flex-col hover:shadow-2xl hover:shadow-green-500/10">
                <div class="h-12 w-12 bg-green-500/10 rounded-xl flex items-center justify-center mb-6 group-hover:scale-110 group-hover:bg-green-500/20 transition-all">
                    <svg aria-hidden="true" class="w-6 h-6 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                </div>
                <h3 class="text-xl font-bold mb-3">Global Interoperability</h3>
                <div class="space-y-4 flex-grow">
                    <div>
                        <span class="text-[10px] font-black uppercase tracking-[0.2em] text-red-400">Problem</span>
                        <p class="text-sm text-slate-400 leading-relaxed mt-1">Proprietary or legacy systems build on outdated technologies that don't talk to each other.</p>
                    </div>
                    <div>
                        <span class="text-[10px] font-black uppercase tracking-[0.2em] text-green-400">Solution</span>
                        <p class="text-sm text-slate-300 leading-relaxed mt-1">
                        I modernize your environment to empower data processing workflows and align with FAIR principles and international standards,
                        ensuring your data is discoverable and integrable on a global scale.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Technical Edge (For Scanners who stay) -->
