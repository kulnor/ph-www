---
layout: layouts/base.njk
title: Pascal Heus | Data, Metadata & AI Strategist
---

<!-- Hero Section -->
<section class="relative min-h-screen flex items-center px-6 overflow-hidden pt-20">
    <div class="max-w-7xl mx-auto grid lg:grid-cols-2 gap-12 items-center">
        <div class="space-y-8 z-10" 
             x-data="{ show: false }" x-init="setTimeout(() => show = true, 100)"
             x-show="show" x-transition:enter="transition ease-out duration-1000" x-transition:enter-start="opacity-0 translate-y-10" x-transition:enter-end="opacity-100 translate-y-0">
            
            <div class="inline-flex items-center space-x-2 glass px-3 py-1.5 rounded-full text-[9px] sm:text-xs font-semibold tracking-wider uppercase text-primary-400 max-w-full">
                <span class="relative flex h-2 w-2 shrink-0">
                  <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary-400 opacity-75"></span>
                  <span class="relative inline-flex rounded-full h-2 w-2 bg-primary-500"></span>
                </span>
                <span class="truncate sm:whitespace-normal">Available for Short-Term Strategic Consultancies • Canada 🇨🇦</span>
            </div>
            
            <h1 class="text-4xl sm:text-6xl md:text-8xl font-black font-display leading-[1.1] md:leading-[0.9] tracking-tighter">
                Elevating <span class="text-gradient">Data</span> into Actionable Knowledge.
            </h1>
            
            <p class="text-lg sm:text-xl text-slate-300 max-w-lg leading-relaxed">
                Decades of IT and scientific expertise bridging technical depth with creative flair to transform data into a machine and user friendly high-value digital commodity.
            </p>
            
            <div class="flex flex-col sm:flex-row gap-4 pt-4">
                <a href="/#services" class="btn-primary flex justify-center items-center">
                    Explore Services
                </a>
                <a href="https://linkedin.com/in/pascal" target="_blank" class="glass px-6 py-3 rounded-full font-semibold flex justify-center items-center hover:bg-white/10 transition-all">
                    View LinkedIn
                </a>
            </div>
        </div>

        <div class="relative hidden lg:block"
             x-data="{ show: false }" x-init="setTimeout(() => show = true, 400)"
             x-show="show" x-transition:enter="transition ease-out duration-1000" x-transition:enter-start="opacity-0 scale-95" x-transition:enter-end="opacity-100 scale-100">
            <!-- Glassy Stats/Quick Info Card -->
            <div class="glass p-8 rounded-3xl space-y-6 relative overflow-hidden group border-white/5 shadow-2xl">
                <div class="absolute -right-10 -top-10 w-40 h-40 bg-primary-500/20 rounded-full blur-3xl group-hover:bg-primary-500/30 transition-all duration-700"></div>
                <div class="absolute -left-10 -bottom-10 w-40 h-40 bg-purple-500/10 rounded-full blur-3xl group-hover:bg-purple-500/20 transition-all duration-700"></div>
                
                <div class="space-y-2">
                    <span class="text-slate-400 text-sm font-medium uppercase tracking-widest">IT Experience</span>
                    <div class="text-6xl font-black font-display tracking-tight">40+ Years</div>
                </div>
                
                <div class="flex items-start gap-8">
                    <div class="space-y-1">
                        <span class="text-slate-400 text-[10px] font-bold uppercase tracking-widest leading-none">High-Value Data</span>
                        <div class="text-lg font-black text-green-400 leading-none">25+ Years</div>
                    </div>
                     <div class="space-y-1">
                        <span class="text-slate-400 text-[10px] font-bold uppercase tracking-widest leading-none">Metadata</span>
                        <div class="text-lg font-black text-primary-400 leading-none">Open/FAIR</div>
                    </div>
                    <div class="space-y-1">
                        <span class="text-slate-400 text-[10px] font-bold uppercase tracking-widest leading-none">AI</span>
                        <div class="text-lg font-black text-purple-400 leading-none">Agentic</div>
                    </div>
                </div>

                <hr class="border-white/10">

                <div class="flex items-center space-x-3 text-slate-300">
                    <div class="h-8 w-8 rounded-lg bg-green-500/20 flex items-center justify-center">
                        <svg class="w-4 h-4 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                    </div>
                    <span class="text-sm font-medium">Jack of all trades, Master of MANY.</span>
                </div>
            </div>
        </div>
    </div>
    
    <div class="absolute bottom-10 left-1/2 -translate-x-1/2 animate-bounce opacity-50">
        <svg class="w-6 h-6 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7-7-7m14-8l-7 7-7-7"></path></svg>
    </div>
</section>

<!-- Services Portfolio -->
<section id="services" class="py-20 px-6">
    <div class="max-w-7xl mx-auto">
        <div class="mb-12 space-y-4 text-center">
            <h2 class="text-4xl md:text-5xl font-bold font-display tracking-tight">Services Portfolio</h2>
            <div class="h-1.5 w-24 bg-primary-500 rounded-full mx-auto"></div>
            <p class="text-slate-400 max-w-2xl mx-auto">
                High-impact, short-term strategic guidance at the intersection of data science and AI. 
                <strong>Consultancy fees directly fund my continued leadership in open standards and pro-bono contributions to the global data community.</strong>
            </p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
            {% for service in services %}
            <div class="glass p-8 rounded-2xl hover:border-primary-500/50 transition-all duration-300 group flex flex-col hover:shadow-2xl hover:shadow-primary-500/10">
                <div class="h-12 w-12 bg-primary-500/10 rounded-xl flex items-center justify-center mb-6 group-hover:scale-110 group-hover:bg-primary-500/20 transition-all">
                    {% if service.icon == 'transformation' %}
                    <svg aria-hidden="true" class="w-6 h-6 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                    {% elif service.icon == 'brain' %}
                    <svg aria-hidden="true" class="w-6 h-6 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path></svg>
                    {% elif service.icon == 'tools' %}
                    <svg aria-hidden="true" class="w-6 h-6 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path></svg>
                    {% elif service.icon == 'enrichment' %}
                    <svg aria-hidden="true" class="w-6 h-6 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4"></path></svg>
                    {% elif service.icon == 'research' %}
                    <svg aria-hidden="true" class="w-6 h-6 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 01-.586 1.414l-2.387 2.387a2 2 0 01-1.414.586H8.966a2 2 0 01-1.414-.586L5.166 11.586A2 2 0 014.58 10.172V5L4 4h4z"></path></svg>
                    {% else %}
                    <svg aria-hidden="true" class="w-6 h-6 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"></path></svg>
                    {% endif %}
                </div>
                <h3 class="text-xl font-bold mb-4">{{ service.title }}</h3>
                <p class="text-slate-400 text-sm leading-relaxed mb-6 flex-grow">
                    {{ service.description }}
                </p>
                <div class="space-y-2 mt-auto">
                    {% for detail in service.details %}
                    <div class="flex items-center space-x-2 text-xs text-slate-300">
                        <span class="w-1.5 h-1.5 rounded-full bg-primary-500/50"></span>
                        <span>{{ detail }}</span>
                    </div>
                    {% endfor %}
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
</section>

<!-- Experience / Professional Journey -->
<section id="about" class="py-20 bg-slate-900/40 px-6 border-y border-white/5">
    <div class="max-w-7xl mx-auto">
        <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-start">
            <div class="space-y-6 lg:space-y-8 lg:sticky lg:top-32">
                <h2 class="text-3xl md:text-4xl font-bold font-display tracking-tight">Professional Journey</h2>
                <p class="text-base md:text-lg text-slate-300 leading-relaxed max-w-lg">
                    With over four decades in information technology, I've seen the evolution of data from rigid punch cards to a fluid, machine-actionable digital commodity.
                </p>
                <div class="space-y-2">
                    <p class="text-xs md:text-sm text-slate-400 font-medium uppercase tracking-widest">
                        Based in Canada 🇨🇦 • Serving Globally 🌎
                    </p>
                    <p class="text-xs md:text-sm text-slate-400 font-medium uppercase tracking-widest">
                        English 🇬🇧 & Français 🇫🇷
                    </p>
                </div>
                
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 md:gap-6 pt-2">
                    <div class="glass p-5 md:p-6 rounded-2xl border-white/5 shadow-xl">
                        <div class="text-3xl md:text-4xl font-bold font-display text-primary-400 tracking-tighter">40y</div>
                        <div class="text-[10px] text-slate-400 uppercase tracking-[0.2em] font-black mt-2 text-nowrap">IT Excellence</div>
                    </div>
                    <div class="glass p-5 md:p-6 rounded-2xl border-white/5 shadow-xl">
                        <div class="text-3xl md:text-4xl font-bold font-display text-purple-400 tracking-tighter">25y</div>
                        <div class="text-[10px] text-slate-400 uppercase tracking-[0.2em] font-black mt-2 text-nowrap">High-Value Data / Metadata</div>
                    </div>
                </div>

                <div class="pt-2">
                    <a href="/assets/docs/HeusPascal.pdf" download class="inline-flex items-center space-x-2 glass px-6 py-3 rounded-xl font-bold hover:bg-white/10 transition-all border-white/10 text-sm w-full sm:w-auto justify-center md:justify-start">
                        <svg class="w-5 h-5 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                        <span>Download Full Resume</span>
                    </a>
                </div>

                <!-- Skill Tags -->
                <div class="pt-8">
                    <h4 class="text-xs font-bold uppercase tracking-widest text-slate-500 mb-6">Mastered Technologies</h4>
                    <div class="flex flex-wrap gap-2">
                        {% for skill in skills.development.strong %}
                        <span class="px-3 py-1.5 rounded-lg bg-primary-500/5 border border-primary-500/20 text-xs font-medium text-primary-300">{{ skill }}</span>
                        {% endfor %}
                        {% for api in skills.apis.strong %}
                        <span class="px-3 py-1.5 rounded-lg bg-purple-500/5 border border-purple-500/20 text-xs font-medium text-purple-300">{{ api }}</span>
                        {% endfor %}
                        {% for ai in skills.ai %}
                        <span class="px-3 py-1.5 rounded-lg bg-green-500/5 border border-green-500/20 text-xs font-medium text-green-300">{{ ai }}</span>
                        {% endfor %}
                    </div>
                </div>
            </div>
            
            <div class="space-y-12">
                {% for exp in experience %}
                <div class="relative pl-8 border-l border-white/10 group">
                    <div class="absolute w-3 h-3 bg-primary-500 rounded-full -left-[6.5px] top-1.5 shadow-[0_0_10px_rgba(14,165,233,0.5)] group-hover:scale-125 transition-transform"></div>
                    <div class="space-y-2">
                        <span class="text-xs font-bold text-primary-500 uppercase tracking-widest">{{ exp.period }}</span>
                        <h3 class="text-2xl font-bold font-display">{{ exp.role }}</h3>
                        <p class="text-slate-400 font-semibold">{{ exp.company }}</p>
                        <p class="text-sm text-slate-400 leading-relaxed mb-4 italic">{{ exp.description }}</p>
                        <ul class="space-y-2 mt-4">
                            {% for highlight in exp.highlights %}
                            <li class="text-sm text-slate-300 flex items-start space-x-3">
                                <svg class="w-4 h-4 mt-0.5 text-primary-500/50 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"></path></svg>
                                <span>{{ highlight }}</span>
                            </li>
                            {% endfor %}
                        </ul>
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>
    </div>
</section>

<!-- Rates & Fees Section -->
<section id="rates" class="py-20 px-6">
    <div class="max-w-7xl mx-auto">
        <div class="mb-12 space-y-4">
            <h2 class="text-4xl font-bold font-display">Consulting Rates</h2>
            <div class="h-1.5 w-20 bg-primary-500 rounded-full"></div>
            <p class="text-slate-400 max-w-2xl mt-4 italic">
                These figures are guidelines. I prioritize high-impact partnership and value creation over rigid fee structures.
                <strong>Consultancy fees directly subsidize my commitment to open-source development and pro-bono services for social impact.</strong>
            </p>
        </div>

        <div class="grid md:grid-cols-3 gap-8">
            {% for rate in rates %}
            <div class="glass p-10 rounded-3xl flex flex-col hover:border-primary-500/30 transition-all border-white/5 shadow-2xl">
                <span class="text-[10px] font-black uppercase tracking-[0.2em] text-primary-500 mb-4">{{ rate.category }}</span>
                <h3 class="text-xl font-bold mb-1">{{ rate.target }}</h3>
                <div class="text-3xl font-black font-display text-white mt-4">{{ rate.range }}</div>
                <p class="text-sm text-slate-400 mt-6 leading-relaxed mb-8 flex-grow">{{ rate.description }}</p>
                
                <div class="space-y-3 pt-6 border-t border-white/5">
                    {% for feature in rate.features %}
                    <div class="flex items-center space-x-3 text-xs text-slate-300">
                        <svg class="w-4 h-4 text-primary-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                        <span>{{ feature }}</span>
                    </div>
                    {% endfor %}
                </div>
            </div>
            {% endfor %}
        </div>
        
        <div class="mt-12 p-8 glass rounded-3xl border-primary-500/10 text-center space-y-4">
            <p class="text-sm text-slate-300 font-medium">
                "My goal is to foster a more data-actionable world. If we share a vision, cost will never be the barrier."
            </p>
            <p class="text-xs text-slate-400 italic">
                By choosing my strategic services, you are directly supporting the development of open data standards and providing machine-actionable knowledge to those who need it most.
            </p>
        </div>
    </div>
</section>

<!-- Project Selection Criteria -->
<section id="criteria" class="py-20 bg-slate-900/40 px-6 border-y border-white/5">
    <div class="max-w-7xl mx-auto">
        <div class="mb-12 space-y-4 text-center">
            <h2 class="text-4xl font-bold font-display">Project Selection</h2>
            <div class="h-1.5 w-20 bg-green-500 rounded-full mx-auto"></div>
            <p class="text-slate-400 mt-4 max-w-xl mx-auto">I'm selective about the projects I take on to ensure I can provide maximum focus and impact.</p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-5 gap-4">
            {% for item in criteria %}
            <div class="glass p-6 rounded-2xl flex flex-col items-center text-center space-y-4 hover:border-green-500/30 transition-all">
                <div class="h-10 w-10 bg-green-500/10 rounded-full flex items-center justify-center">
                    <svg class="w-5 h-5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                </div>
                <h3 class="font-bold text-sm uppercase tracking-wider">{{ item.title }}</h3>
                <p class="text-xs text-slate-400 leading-relaxed">{{ item.description }}</p>
            </div>
            {% endfor %}
        </div>
    </div>
</section>

<!-- R&D & Community Section -->
<section id="projects" class="py-20 px-6 overflow-hidden relative">
    <div class="absolute -right-64 top-0 w-96 h-96 bg-primary-500/5 rounded-full blur-[120px]"></div>
    <div class="max-w-7xl mx-auto">
        <div class="mb-12 space-y-4">
            <h2 class="text-4xl font-bold font-display leading-tight">Giving Back: <span class="text-gradient">R&D & Community</span></h2>
            <div class="h-1.5 w-20 bg-purple-500 rounded-full"></div>
            <p class="text-slate-400 max-w-2xl">A selection of open-source projects, global standards, and visionary data initiatives I actively contribute to or lead.</p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
            {% for project in projects %}
            <a href="{{ project.url }}" target="_blank" class="glass p-6 rounded-2xl hover:bg-white/10 transition-all group relative overflow-hidden">
                <div class="absolute right-4 top-4 opacity-10 group-hover:opacity-100 transition-opacity">
                    <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
                </div>
                <span class="text-[10px] font-bold uppercase tracking-widest text-purple-400 mb-2 block">{{ project.type }}</span>
                <h3 class="text-lg font-bold mb-2 group-hover:text-primary-400 transition-colors">{{ project.title }}</h3>
                <p class="text-sm text-slate-400 leading-relaxed">{{ project.description }}</p>
            </a>
            {% endfor %}
        </div>
    </div>
</section>

