                        </div>
                    </div>
                </div>
            </div>
        </div>

        {# Mastered Technologies — commented out, may bring back later
        <div class="pt-12 text-center">
            <h4 class="text-xs font-bold uppercase tracking-widest text-slate-500 mb-6">Mastered Technologies</h4>
