<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/png" href="/assets/img/favicon.png">
    <title>{{ title or site.name }}</title>
    <meta name="description" content="{{ description or site.description }}">
    <link rel="canonical" href="{{ site.url }}{{ page.url }}">

    <meta name="keywords" content="Pascal Heus, Data Strategist, AI, Metadata, DDI, SDMX, Agentic AI, Digital Transformation">
    <meta name="author" content="{{ site.author }}">
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website">
    <meta property="og:url" content="{{ site.url }}{{ page.url }}">
    <meta property="og:title" content="{{ title or site.name }}">
    <meta property="og:description" content="{{ description or site.description }}">
    <meta property="og:image" content="{{ site.url }}{{ site.ogImage }}">
    <meta property="og:image:alt" content="Pascal Heus - Data & AI Strategist">

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image">
    <meta property="twitter:url" content="{{ site.url }}{{ page.url }}">
    <meta property="twitter:title" content="{{ title or site.name }}">
    <meta property="twitter:description" content="{{ description or site.description }}">
    <meta property="twitter:image" content="{{ site.url }}{{ site.ogImage }}">

    <!-- Structured Data (JSON-LD) -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Pascal Heus",
      "url": "{{ site.url }}",
      "jobTitle": "Data & AI Strategist",
      "sameAs": [
        "https://linkedin.com/in/pascal",
        "https://github.com/kulnor"
      ],
      "description": "{{ site.description }}"
    }
    </script>

    <link rel="stylesheet" href="/assets/css/main.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@400;600;700;800&display=swap" rel="stylesheet">
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <style>
        [x-cloak] { display: none !important; }
    </style>
</head>
<body class="bg-slate-950 text-slate-100 overflow-x-hidden" x-data="{ scrolled: false }" @scroll.window="scrolled = (window.pageYOffset > 20)">
    
    <!-- Hero Background Canvas -->
    <div id="hero-canvas-container" class="fixed inset-0 -z-10 opacity-30 pointer-events-none"></div>

    <!-- Navigation -->
    <nav class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 px-6 py-4" :class="{ 'bg-slate-950/80 backdrop-blur-lg border-b border-white/10 py-3': scrolled }">
        <div class="max-w-7xl mx-auto flex justify-between items-center">
            <a href="/" class="text-2xl font-bold font-display tracking-tight text-white">
                <span class="text-primary-500">P</span>ascal <span class="text-primary-500">H</span>eus
            </a>
            
            <div class="hidden lg:flex space-x-6 text-xs font-bold uppercase tracking-widest">
                <a href="/#services" class="hover:text-primary-400 transition-colors">Services</a>
                <a href="/#about" class="hover:text-primary-400 transition-colors">Journey</a>
                <a href="/#rates" class="hover:text-primary-400 transition-colors">Fees</a>
                <a href="/#criteria" class="hover:text-primary-400 transition-colors">Focus</a>
                <a href="/#projects" class="hover:text-primary-400 transition-colors">R&D</a>
                <a href="/#contact" class="hover:text-primary-400 transition-colors">Contact</a>
            </div>

            <a href="https://linkedin.com/in/pascal" target="_blank" class="glass px-4 py-2 rounded-full text-sm font-semibold hover:bg-white/10 transition-colors">
                LinkedIn
            </a>
        </div>
    </nav>

    <main>
        {{ content | safe }}
    </main>

    <!-- Footer -->
    <footer class="bg-slate-900 border-t border-white/5 py-12 px-6">
        <div class="max-w-7xl mx-auto text-center md:text-left flex flex-col md:flex-row justify-between items-center space-y-8 md:space-y-0">
            <div>
                <p class="text-sm text-slate-400">&copy; {{ page.date.getFullYear() }} Pascal Heus. All rights reserved.</p>
            </div>
            <div class="flex space-x-6 text-sm">
                <a href="/privacy" class="text-slate-400 hover:text-white transition-colors">Privacy Policy</a>
                <a href="/terms" class="text-slate-400 hover:text-white transition-colors">Terms of Service</a>
            </div>
        </div>
    </footer>

    <script type="module" src="/assets/js/three-scene.js"></script>
    <script src="/assets/js/main.js"></script>
</body>
</html>
